---
import BaseLayout from '../layouts/BaseLayout.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import { siteConfig } from '../site.config';

const { about, testimonials } = siteConfig;
---

<BaseLayout
  title="About Ash | Smart Water Window Cleaning Doncaster"
  description="Meet Ash, the man behind Smart Water Window Cleaning Services. 350+ regular customers across Doncaster. Reliable, friendly, and always does a proper job."
>
  <!-- ── Header ─────────────────────────────────────────────── -->
  <section class="bg-gradient-to-br from-[var(--color-accent-secondary)] to-[#1e4a80] text-white py-16 md:py-20">
    <div class="section py-0">
      <div class="max-w-3xl">
        <div class="accent-line" style="background: linear-gradient(90deg, #3AADE0, #ffffff);"></div>
        <h1 class="text-4xl sm:text-5xl font-heading font-extrabold text-white mb-4 animate-fade-in">
          About Ash
        </h1>
        <p class="text-lg text-blue-100 leading-relaxed animate-fade-in-up" style="animation-delay: 0.2s;">
          The man behind Smart Water. One bloke, 350+ happy customers.
        </p>
      </div>
    </div>
  </section>

  <!-- ── Bio ──────────────────────────────────────────────── -->
  <section class="section">
    <div class="grid md:grid-cols-5 gap-12 items-start">
      <!-- Photo placeholder -->
      <div class="md:col-span-2 reveal">
        <div class="bg-[var(--color-bg-secondary)] rounded-2xl aspect-[3/4] max-w-sm mx-auto md:mx-0 flex items-center justify-center border border-gray-100 overflow-hidden">
          <div class="text-center p-8">
            <div class="w-24 h-24 rounded-full bg-[var(--color-accent)]/20 border-2 border-[var(--color-accent)]/30 mx-auto mb-4 flex items-center justify-center">
              <span class="text-3xl font-heading font-bold text-[var(--color-accent)]">A</span>
            </div>
            <p class="text-sm text-[var(--color-text-secondary)]">
              Photo coming soon
            </p>
          </div>
        </div>
      </div>

      <!-- Bio text -->
      <div class="md:col-span-3 reveal" style="transition-delay: 0.15s;">
        <h2 class="font-heading font-bold text-2xl text-[var(--color-accent-secondary)] mb-1">{about.founderName}</h2>
        <p class="text-[var(--color-accent)] font-medium mb-6">{about.founderRole}</p>

        {about.bio.split('\n\n').map((paragraph) => (
          <p class="text-[var(--color-text-secondary)] leading-relaxed mb-4">{paragraph}</p>
        ))}

        <div class="border-t border-gray-100 pt-6 mt-6">
          <h3 class="font-heading font-semibold text-lg text-[var(--color-accent-secondary)] mb-3">How Ash Works</h3>
          <p class="text-[var(--color-text-secondary)] leading-relaxed">{about.philosophy}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Values ────────────────────────────────────────────── -->
  <section class="bg-[var(--color-bg-secondary)] py-20">
    <div class="section py-0">
      <div class="text-center mb-12">
        <div class="accent-line mx-auto reveal"></div>
        <h2 class="section-heading reveal">Why Customers Stick With Ash</h2>
      </div>
      <div class="grid sm:grid-cols-3 gap-6">
        {about.values.map((value, i) => (
          <div class="bg-white rounded-xl p-8 reveal border border-gray-100" style={`transition-delay: ${i * 0.1}s;`}>
            <h3 class="font-heading font-bold text-lg text-[var(--color-accent-secondary)] mb-3">{value.title}</h3>
            <p class="text-[var(--color-text-secondary)] text-sm leading-relaxed">{value.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Testimonials ──────────────────────────────────────── -->
  <section class="section">
    <div class="text-center mb-12">
      <div class="accent-line mx-auto reveal"></div>
      <h2 class="section-heading reveal">What People Say</h2>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {testimonials.slice(0, 3).map((t, i) => (
        <TestimonialCard
          quote={t.quote}
          name={t.name}
          index={i}
        />
      ))}
    </div>
  </section>

  <!-- ── CTA ───────────────────────────────────────────────── -->
  <section class="bg-gradient-to-br from-[var(--color-accent-secondary)] to-[#1e4a80] text-white py-16">
    <div class="section py-0 text-center reveal">
      <h2 class="text-3xl font-heading font-bold text-white mb-4">Want to Become a Regular?</h2>
      <p class="text-blue-100 mb-8 max-w-lg mx-auto">
        Join 350+ customers across Doncaster who already trust Ash with their windows and exteriors.
      </p>
      <a href={`https://wa.me/${siteConfig.whatsapp}`} target="_blank" rel="noopener noreferrer" class="btn-whatsapp text-base">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Get in Touch With Ash
      </a>
    </div>
  </section>
</BaseLayout>
