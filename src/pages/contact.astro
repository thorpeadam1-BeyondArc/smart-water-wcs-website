---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import ArcMotif from '../components/ArcMotif.astro';
import { siteConfig } from '../site.config';

const { contact, name, email, location, phone } = siteConfig;
---

<BaseLayout
  title={`Contact — ${name}`}
  description={`Get in touch with ${name}. ${contact.subline}`}
>
  <section class="section pt-24 md:pt-32">
    <div class="accent-line reveal"></div>
    <h1 class="section-heading reveal">{contact.heading}</h1>
    <p class="section-subline reveal">{contact.subline}</p>
  </section>

  <section class="section pt-0">
    <div class="grid md:grid-cols-2 gap-16">
      <!-- Form -->
      <div class="reveal">
        <ContactForm />
      </div>

      <!-- Contact details -->
      <div class="reveal" style="transition-delay: 0.15s;">
        <div class="glass-surface p-8 space-y-8">
          <!-- Email -->
          <div>
            <h3 class="font-heading font-semibold text-sm text-white uppercase tracking-wider mb-2">Email</h3>
            <a
              href={`mailto:${email}`}
              class="text-[var(--color-accent)] hover:underline break-all"
            >
              {email}
            </a>
          </div>

          <!-- Phone -->
          {phone && (
            <div>
              <h3 class="font-heading font-semibold text-sm text-white uppercase tracking-wider mb-2">Phone</h3>
              <a
                href={`tel:${phone.replace(/\s/g, '')}`}
                class="text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] transition-colors"
              >
                {phone}
              </a>
            </div>
          )}

          <!-- Location -->
          {location && (
            <div>
              <h3 class="font-heading font-semibold text-sm text-white uppercase tracking-wider mb-2">Location</h3>
              <p class="text-[var(--color-text-secondary)]">{location}</p>
            </div>
          )}

          <!-- Social -->
          {(siteConfig.linkedin || siteConfig.twitter || siteConfig.instagram) && (
            <div>
              <h3 class="font-heading font-semibold text-sm text-white uppercase tracking-wider mb-3">Follow</h3>
              <div class="flex gap-4">
                {siteConfig.linkedin && (
                  <a href={siteConfig.linkedin} target="_blank" rel="noopener noreferrer" class="text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] transition-colors min-w-[48px] min-h-[48px] flex items-center justify-center glass-card !p-2 !rounded-lg" aria-label="LinkedIn">
                    <span class="text-sm font-medium">in</span>
                  </a>
                )}
                {siteConfig.twitter && (
                  <a href={siteConfig.twitter} target="_blank" rel="noopener noreferrer" class="text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] transition-colors min-w-[48px] min-h-[48px] flex items-center justify-center glass-card !p-2 !rounded-lg" aria-label="Twitter">
                    <span class="text-sm font-medium">X</span>
                  </a>
                )}
                {siteConfig.instagram && (
                  <a href={siteConfig.instagram} target="_blank" rel="noopener noreferrer" class="text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] transition-colors min-w-[48px] min-h-[48px] flex items-center justify-center glass-card !p-2 !rounded-lg" aria-label="Instagram">
                    <span class="text-sm font-medium">IG</span>
                  </a>
                )}
              </div>
            </div>
          )}
        </div>

        <ArcMotif class="mt-8" flip />
      </div>
    </div>
  </section>
</BaseLayout>
