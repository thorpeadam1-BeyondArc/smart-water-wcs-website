---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import { siteConfig } from '../site.config';
---

<BaseLayout
  title="Contact | Smart Water Window Cleaning Doncaster"
  description="Get a free window cleaning quote in Doncaster. WhatsApp or call Ash on 07542 472139. Covering Warmsworth, Edlington, Balby, Cusworth, Scawsby & surrounding areas."
>
  <!-- ── Header ─────────────────────────────────────────────── -->
  <section class="bg-gradient-to-br from-[var(--color-accent-secondary)] to-[#1e4a80] text-white py-16 md:py-20">
    <div class="section py-0">
      <div class="max-w-3xl">
        <div class="accent-line" style="background: linear-gradient(90deg, #3AADE0, #ffffff);"></div>
        <h1 class="text-4xl sm:text-5xl font-heading font-extrabold text-white mb-4 animate-fade-in">
          Get a Free Quote
        </h1>
        <p class="text-lg text-blue-100 leading-relaxed animate-fade-in-up" style="animation-delay: 0.2s;">
          {siteConfig.contact.subline}
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="grid md:grid-cols-2 gap-16">
      <!-- WhatsApp primary + contact details -->
      <div class="reveal">
        <!-- WhatsApp CTA -->
        <div class="bg-[var(--color-bg-secondary)] rounded-2xl p-8 mb-8 border border-gray-100">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 rounded-full bg-[#25D366] flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="white" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <div>
              <h2 class="font-heading font-bold text-lg text-[var(--color-accent-secondary)]">WhatsApp Ash</h2>
              <p class="text-sm text-[var(--color-text-secondary)]">Quickest way to get a quote</p>
            </div>
          </div>
          <p class="text-[var(--color-text-secondary)] text-sm mb-6 leading-relaxed">
            Drop Ash a WhatsApp message with your postcode and what you need doing. Most people hear back within a couple of hours.
          </p>
          <a href={`https://wa.me/${siteConfig.whatsapp}`} target="_blank" rel="noopener noreferrer" class="btn-whatsapp w-full justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Message Ash on WhatsApp
          </a>
        </div>

        <!-- Other contact methods -->
        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg bg-[var(--color-bg-secondary)] flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
              </svg>
            </div>
            <div>
              <h3 class="font-heading font-semibold text-sm text-[var(--color-accent-secondary)]">Phone</h3>
              <a href={`tel:${siteConfig.phone.replace(/\s/g, '')}`} class="text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] transition-colors">
                {siteConfig.phone}
              </a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg bg-[var(--color-bg-secondary)] flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 01-2.06 0L2 7"/>
              </svg>
            </div>
            <div>
              <h3 class="font-heading font-semibold text-sm text-[var(--color-accent-secondary)]">Email</h3>
              <a href={`mailto:${siteConfig.email}`} class="text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] transition-colors break-all">
                {siteConfig.email}
              </a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg bg-[var(--color-bg-secondary)] flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0116 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div>
              <h3 class="font-heading font-semibold text-sm text-[var(--color-accent-secondary)]">Covering</h3>
              <p class="text-[var(--color-text-secondary)] text-sm">
                {siteConfig.serviceAreas.join(', ')}
              </p>
              <p class="text-[var(--color-text-secondary)] text-xs mt-1">
                Postcodes: {siteConfig.servicePostcodes.join(', ')}
              </p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg bg-[var(--color-bg-secondary)] flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="#1877F2" aria-hidden="true">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </div>
            <div>
              <h3 class="font-heading font-semibold text-sm text-[var(--color-accent-secondary)]">Facebook</h3>
              <a href={siteConfig.facebook} target="_blank" rel="noopener noreferrer" class="text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] transition-colors">
                See reviews & latest work
                <span class="sr-only">(opens in new tab)</span>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Email form (secondary) -->
      <div class="reveal" style="transition-delay: 0.15s;">
        <div class="bg-[var(--color-bg-secondary)] rounded-2xl p-8 border border-gray-100">
          <h2 class="font-heading font-bold text-xl text-[var(--color-accent-secondary)] mb-2">Prefer Email?</h2>
          <p class="text-sm text-[var(--color-text-secondary)] mb-6">
            No problem. Fill in the form below and Ash will get back to you.
          </p>
          <ContactForm />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
