---
/**
 * StarField — the signature Beyond Arc deep-space background.
 * Renders three layers of animated stars with parallax depth.
 */
---

<div class="star-field fixed inset-0 -z-10 overflow-hidden" aria-hidden="true">
  <div class="stars-layer stars-small"></div>
  <div class="stars-layer stars-medium"></div>
  <div class="stars-layer stars-large"></div>
  <!-- Subtle radial gradient overlay -->
  <div class="absolute inset-0" style="background: radial-gradient(ellipse at 50% 0%, rgba(0,217,255,0.03) 0%, transparent 60%);"></div>
</div>

<style>
  .star-field {
    background: var(--color-bg-primary);
  }

  .stars-layer {
    position: absolute;
    inset: 0;
    background-repeat: repeat;
  }

  /* Small stars — many, faint, slow drift */
  .stars-small {
    background-image:
      radial-gradient(1px 1px at 10% 20%, rgba(255,255,255,0.6), transparent),
      radial-gradient(1px 1px at 25% 45%, rgba(255,255,255,0.4), transparent),
      radial-gradient(1px 1px at 40% 10%, rgba(255,255,255,0.5), transparent),
      radial-gradient(1px 1px at 55% 70%, rgba(255,255,255,0.3), transparent),
      radial-gradient(1px 1px at 70% 30%, rgba(255,255,255,0.45), transparent),
      radial-gradient(1px 1px at 85% 55%, rgba(255,255,255,0.35), transparent),
      radial-gradient(1px 1px at 15% 80%, rgba(255,255,255,0.5), transparent),
      radial-gradient(1px 1px at 60% 90%, rgba(255,255,255,0.3), transparent),
      radial-gradient(1px 1px at 90% 85%, rgba(255,255,255,0.4), transparent),
      radial-gradient(1px 1px at 35% 60%, rgba(255,255,255,0.35), transparent);
    background-size: 300px 300px;
    animation: drift 120s linear infinite;
  }

  /* Medium stars */
  .stars-medium {
    background-image:
      radial-gradient(1.5px 1.5px at 20% 30%, rgba(255,255,255,0.7), transparent),
      radial-gradient(1.5px 1.5px at 50% 60%, rgba(255,255,255,0.5), transparent),
      radial-gradient(1.5px 1.5px at 75% 20%, rgba(255,255,255,0.6), transparent),
      radial-gradient(1.5px 1.5px at 30% 80%, rgba(255,255,255,0.4), transparent),
      radial-gradient(1.5px 1.5px at 90% 50%, rgba(255,255,255,0.55), transparent);
    background-size: 400px 400px;
    animation: drift 80s linear infinite reverse;
  }

  /* Large stars — few, bright, with glow */
  .stars-large {
    background-image:
      radial-gradient(2px 2px at 15% 25%, rgba(0,217,255,0.8), transparent 4px),
      radial-gradient(2px 2px at 65% 45%, rgba(212,165,116,0.6), transparent 4px),
      radial-gradient(2.5px 2.5px at 45% 75%, rgba(255,255,255,0.9), transparent 5px),
      radial-gradient(2px 2px at 85% 15%, rgba(0,217,255,0.5), transparent 4px);
    background-size: 500px 500px;
    animation: drift 200s linear infinite, twinkle-field 6s ease-in-out infinite;
  }

  @keyframes drift {
    from { transform: translate(0, 0); }
    to { transform: translate(-100px, -50px); }
  }

  @keyframes twinkle-field {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.7; }
  }

  @media (prefers-reduced-motion: reduce) {
    .stars-small,
    .stars-medium,
    .stars-large {
      animation: none;
    }
  }
</style>
