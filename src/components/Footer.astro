---
import { siteConfig } from '../site.config';

const pages = siteConfig.pages;
const year = new Date().getFullYear();

const footerLinks = [
  pages.about && { label: 'About', href: '/about' },
  pages.services && { label: 'Services', href: '/services' },
  pages.contact && { label: 'Contact', href: '/contact' },
  pages.privacy && { label: 'Privacy', href: '/privacy' },
].filter(Boolean) as { label: string; href: string }[];

const socialLinks = [
  siteConfig.linkedin && { label: 'LinkedIn', href: siteConfig.linkedin },
  siteConfig.twitter && { label: 'Twitter', href: siteConfig.twitter },
  siteConfig.instagram && { label: 'Instagram', href: siteConfig.instagram },
  siteConfig.newsletter && { label: 'Newsletter', href: siteConfig.newsletter },
].filter(Boolean) as { label: string; href: string }[];
---

<footer class="border-t border-white/5 mt-24" role="contentinfo">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid md:grid-cols-3 gap-12">
      <!-- Brand -->
      <div>
        <h3 class="font-heading font-bold text-lg text-white mb-3">{siteConfig.name}</h3>
        <p class="text-[var(--color-text-secondary)] text-sm leading-relaxed mb-4">
          {siteConfig.tagline}
        </p>
        {siteConfig.location && (
          <p class="text-[var(--color-text-secondary)] text-sm">{siteConfig.location}</p>
        )}
      </div>

      <!-- Navigation -->
      <div>
        <h4 class="font-heading font-semibold text-sm text-white uppercase tracking-wider mb-4">Navigation</h4>
        <ul class="space-y-2" role="list">
          {footerLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Connect -->
      <div>
        <h4 class="font-heading font-semibold text-sm text-white uppercase tracking-wider mb-4">Connect</h4>
        <ul class="space-y-2" role="list">
          <li>
            <a href={`mailto:${siteConfig.email}`} class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] transition-colors">
              {siteConfig.email}
            </a>
          </li>
          {siteConfig.phone && (
            <li>
              <a href={`tel:${siteConfig.phone.replace(/\s/g, '')}`} class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] transition-colors">
                {siteConfig.phone}
              </a>
            </li>
          )}
          {socialLinks.map((link) => (
            <li>
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] transition-colors"
              >
                {link.label} <span class="sr-only">(opens in new tab)</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/5 mt-12 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-[var(--color-text-secondary)]">
        &copy; {year} {siteConfig.name}. {siteConfig.footer.copyright}
      </p>
      {siteConfig.footer.builtBy && (
        <p class="text-xs text-[var(--color-text-secondary)]">
          Built by{' '}
          <a
            href={siteConfig.footer.builtBy.url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-[var(--color-accent)] hover:underline"
          >
            {siteConfig.footer.builtBy.name}
          </a>
        </p>
      )}
    </div>
  </div>
</footer>
