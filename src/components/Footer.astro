---
import { siteConfig } from '../site.config';

const pages = siteConfig.pages;
const year = new Date().getFullYear();

const footerLinks = [
  pages.home && { label: 'Home', href: '/' },
  pages.services && { label: 'Services', href: '/services' },
  pages.about && { label: 'About', href: '/about' },
  pages.contact && { label: 'Contact', href: '/contact' },
  pages.privacy && { label: 'Privacy', href: '/privacy' },
].filter(Boolean) as { label: string; href: string }[];
---

<footer class="bg-[var(--color-accent-secondary)] text-white mt-0" role="contentinfo">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid md:grid-cols-3 gap-12">
      <!-- Brand -->
      <div>
        <img src="/logo-icon.png?v=2" alt={`${siteConfig.fullName} logo`} class="h-16 w-auto mb-4" />
        <p class="text-blue-200 text-sm leading-relaxed mb-4">
          {siteConfig.tagline}
        </p>
        <p class="text-blue-200 text-sm">{siteConfig.location}</p>
      </div>

      <!-- Navigation -->
      <div>
        <h4 class="font-heading font-semibold text-sm uppercase tracking-wider mb-4">Navigation</h4>
        <ul class="space-y-2" role="list">
          {footerLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-blue-200 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-heading font-semibold text-sm uppercase tracking-wider mb-4">Get in Touch</h4>
        <ul class="space-y-3" role="list">
          <li>
            <a
              href={`https://wa.me/${siteConfig.whatsapp}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm text-blue-200 hover:text-white transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              WhatsApp Ash
            </a>
          </li>
          <li>
            <a href={`tel:${siteConfig.phone.replace(/\s/g, '')}`} class="inline-flex items-center gap-2 text-sm text-blue-200 hover:text-white transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
              </svg>
              {siteConfig.phone}
            </a>
          </li>
          <li>
            <a href={`mailto:${siteConfig.email}`} class="inline-flex items-center gap-2 text-sm text-blue-200 hover:text-white transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 01-2.06 0L2 7"/>
              </svg>
              {siteConfig.email}
            </a>
          </li>
          {siteConfig.facebook && (
            <li>
              <a
                href={siteConfig.facebook}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 text-sm text-blue-200 hover:text-white transition-colors"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
                Facebook
                <span class="sr-only">(opens in new tab)</span>
              </a>
            </li>
          )}
        </ul>
      </div>
    </div>

    <!-- Service Areas -->
    <div class="border-t border-white/10 mt-12 pt-8">
      <p class="text-sm text-blue-200 mb-1">
        <strong class="text-white">Covering:</strong> {siteConfig.serviceAreas.join(' \u00B7 ')}
      </p>
      <p class="text-sm text-blue-200">
        <strong class="text-white">Postcodes:</strong> {siteConfig.servicePostcodes.join(', ')} &bull; Fully insured
      </p>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/10 mt-6 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-blue-300">
        &copy; {year} {siteConfig.fullName}. {siteConfig.footer.copyright}
      </p>
      {siteConfig.footer.builtBy && (
        <p class="text-xs text-blue-300">
          Built by{' '}
          <a
            href={siteConfig.footer.builtBy.url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-blue-200 hover:text-white hover:underline"
          >
            {siteConfig.footer.builtBy.name}
          </a>
        </p>
      )}
    </div>
  </div>
</footer>
