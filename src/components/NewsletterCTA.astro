---
import { siteConfig } from '../site.config';

const show = Boolean(siteConfig.newsletter);
---

{show && (
  <section class="section reveal">
    <div class="glass-surface p-12 text-center max-w-3xl mx-auto">
      <h2 class="section-heading gradient-text mb-4">Stay in the Loop</h2>
      <p class="text-[var(--color-text-secondary)] mb-8 max-w-lg mx-auto">
        Subscribe to our newsletter for insights, updates, and behind-the-scenes thinking.
      </p>
      <a
        href={siteConfig.newsletter}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary inline-flex"
      >
        Subscribe
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14L21 3"/>
        </svg>
      </a>
    </div>
  </section>
)}
