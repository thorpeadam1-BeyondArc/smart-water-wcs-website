---
import { siteConfig } from '../site.config';
---

<form id="contact-form" class="space-y-6 max-w-xl" novalidate>
  <div>
    <label for="contact-name" class="block text-sm font-medium text-[var(--color-text-secondary)] mb-2">Name</label>
    <input
      type="text"
      id="contact-name"
      name="name"
      required
      placeholder="Your name"
      class="w-full px-4 py-3 bg-white border border-gray-200 rounded-lg text-[var(--color-text-primary)] placeholder:text-gray-400 focus:border-[var(--color-accent)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)]/20 transition-all min-h-[48px]"
    />
  </div>

  <div>
    <label for="contact-email" class="block text-sm font-medium text-[var(--color-text-secondary)] mb-2">Email</label>
    <input
      type="email"
      id="contact-email"
      name="email"
      required
      placeholder="your@email.com"
      class="w-full px-4 py-3 bg-white border border-gray-200 rounded-lg text-[var(--color-text-primary)] placeholder:text-gray-400 focus:border-[var(--color-accent)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)]/20 transition-all min-h-[48px]"
    />
  </div>

  <div>
    <label for="contact-message" class="block text-sm font-medium text-[var(--color-text-secondary)] mb-2">Message</label>
    <textarea
      id="contact-message"
      name="message"
      required
      rows="5"
      placeholder="Tell us about the job..."
      class="w-full px-4 py-3 bg-white border border-gray-200 rounded-lg text-[var(--color-text-primary)] placeholder:text-gray-400 focus:border-[var(--color-accent)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)]/20 transition-all resize-y min-h-[120px]"
    ></textarea>
  </div>

  <button type="submit" class="btn-primary w-full sm:w-auto">
    Send Message
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M5 12h14M12 5l7 7-7 7"/>
    </svg>
  </button>
</form>

<script define:vars={{ recipient: siteConfig.email }}>
  const form = document.getElementById('contact-form');
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const name = (document.getElementById('contact-name')).value.trim();
      const email = (document.getElementById('contact-email')).value.trim();
      const message = (document.getElementById('contact-message')).value.trim();

      if (!name || !email || !message) {
        form.reportValidity();
        return;
      }

      const subject = `Quote request from ${name}`;
      const body = `Name: ${name}\nEmail: ${email}\n\n${message}`;

      // encodeURIComponent uses %20 for spaces (correct for mailto),
      // unlike form-urlencoded which uses + (which iOS Mail doesn't decode).
      const href = `mailto:${recipient}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
      window.location.href = href;
    });
  }
</script>
